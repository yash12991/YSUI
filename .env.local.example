# Google Gemini API Key (Optional - used when AI_PROVIDER=gemini)
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional - used when AI_PROVIDER=groq)
# Get your API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AI Provider to use: 'groq' or 'gemini' (default: 'groq')
# Groq is faster and more cost-effective, Gemini is more advanced
AI_PROVIDER=groq
